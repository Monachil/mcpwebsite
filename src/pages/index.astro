  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">Asset-Backed Lending &middot; Specialty Finance</p>
    <div class="hero-rule"></div>
    <h1>Differentiated Alpha<br>through <strong>Disciplined Investing</strong></h1>
    <p class="hero-text">Senior-secured, asset-backed private credit. Greenwich, CT.</p>
    <div class="hero-actions">
      <a href="/approach/" class="btn btn--primary">Our Approach</a>
      <a href="/contact/" class="btn btn--outline">Get in Touch</a>
    </div>
  </div>
</section>

<section class="stats">
  <div class="container">
    <div class="stats-grid">
      <div class="fade-in">
        <p class="stat-number">{site.yearsTrackRecord}+</p>
        <p class="stat-label">Years Track Record</p>
      </div>
      <div class="fade-in">
        <p class="stat-number">$5–30M</p>
        <p class="stat-label">Typical Deal Size</p>
      </div>
      <div class="fade-in">
        <p class="stat-number">$30M+</p>
        <p class="stat-label">Senior Management Capital Committed</p>
      </div>
      <div class="fade-in">
        <p class="stat-number">2</p>
        <p class="stat-label">Investment Vehicles</p>
      </div>
    </div>
    <p class="stats-disclaimer">All investments involve risk, including possible loss of principal. Past performance is not indicative of future results.</p>
  </div>
</section>

<section class="section fade-in">
  <div class="container">
    <div class="who-grid">
      <div>
        <div class="section-header">
          <p class="section-label">Who We Are</p>
          <h2 class="section-title">Built on <strong>risk management</strong>, powered by data</h2>
        </div>
        <div class="who-text">
          <p>We directly originate privately negotiated, senior-secured investments and differentiate ourselves with a <strong>data-driven approach</strong> — monitoring and reconciling collateral in near real time. By partnering with high-growth specialty finance originators, we deliver <strong>consistent current income</strong> with downside protection as the foundation.</p>
          <a href="/about/" class="btn btn--ghost">About Us &rarr;</a>
        </div>
      </div>
      <div class="pillars">
        <div class="pillar">
          <div class="pillar-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <div>
            <p class="pillar-title">Downside Protection First</p>
            <p class="pillar-desc">Capital preservation underwriting mandate with control, transparency, and structural seniority as foundation.</p>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
          <div>
            <p class="pillar-title">Data-Driven Process</p>
            <p class="pillar-desc">Proprietary risk platform with real-time analytics powering deal-level and portfolio risk management.</p>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <div>
            <p class="pillar-title">Experienced Leadership</p>
            <p class="pillar-desc">Senior team with 20+ years of structured credit experience across market cycles.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section--alt fade-in">
  <div class="container">
    <div class="section-header section-header--centered">
      <p class="section-label">Our Approach</p>
      <h2 class="section-title">Disciplined, <strong>Repeatable</strong> Process</h2>
      <p class="section-subtitle mx-auto">Proprietary data analytics powering every decision — from sourcing through ongoing portfolio surveillance.</p>
    </div>
    <div class="process-preview">
      <div class="process-step">
        <span class="process-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
        <span class="process-name">Source</span>
      </div>
      <div class="process-step">
        <span class="process-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></span>
        <span class="process-name">Underwrite</span>
      </div>
      <div class="process-step">
        <span class="process-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></span>
        <span class="process-name">Execute</span>
      </div>
      <div class="process-step">
        <span class="process-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></span>
        <span class="process-name">Monitor</span>
      </div>
      <div class="process-step">
        <span class="process-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
        <span class="process-name">Manage</span>
      </div>
    </div>
    <div class="section-cta">
      <a href="/approach/" class="btn btn--ghost">Our Approach &rarr;</a>
    </div>
  </div>
</section>

<section class="section fade-in">
  <div class="container">
    <div class="section-header section-header--split">
      <div>
        <p class="section-label">Research & Insights</p>
        <h2 class="section-title">Latest from <strong>Monachil</strong></h2>
      </div>
      <a href="/research/" class="btn btn--ghost">View All &rarr;</a>
    </div>
    <div class="cards-grid">
      {latestResearch.length > 0 ? (
        latestResearch.map(article => (
          <a href={`/research/${article.id}/`} class="card">
            <p class="card-date">{article.data.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
            {article.data.category && <span class="card-category">{article.data.category}</span>}
            <h3 class="card-title">{article.data.title}</h3>
            <p class="card-excerpt">{article.data.description}</p>
            <span class="card-link">Read Article &rarr;</span>
          </a>
        ))
      ) : (
        <div class="card">
          <p class="card-date">Coming Soon</p>
          <h3 class="card-title">Monthly Market Commentary</h3>
          <p class="card-excerpt">Our research and insights will be published here. Subscribe to stay informed.</p>
        </div>
      )}
    </div>
  </div>
</section>

<section class="section section--alt fade-in">
  <div class="container">
    <div class="section-header section-header--split">
      <div>
        <p class="section-label">In the Media</p>
        <h2 class="section-title">Recent <strong>Appearances</strong></h2>
      </div>
      <a href="/media/" class="btn btn--ghost">View All &rarr;</a>
    </div>
    <div class="media-grid media-grid--home">
      {latestMedia.map(video => (video.youtubeId || video.embedUrl) ? (
        <div class="media-card media-card--embed" {...(video.youtubeId ? { 'data-youtube': video.youtubeId } : { 'data-embed': video.embedUrl })}>
          <div class="media-card-thumb">
            <img src={video.image} alt={video.imageAlt} class="media-card-thumb-img" loading="lazy" decoding="async">
            <span class="media-card-source">{video.source}</span>
            <div class="media-card-play"></div>
          </div>
          <div class="media-card-body">
            <p class="media-card-date">{video.date}</p>
            <h3 class="media-card-title">{video.title}</h3>
          </div>
        </div>
      ) : (
        <a href={video.url} target="_blank" rel="noopener" class="media-card media-card--external">
          <div class="media-card-thumb">
            <img src={video.image} alt={video.imageAlt} class="media-card-thumb-img" loading="lazy" decoding="async">
            <span class="media-card-source">{video.source}</span>
            <div class="media-card-play media-card-play--external"></div>
          </div>
          <div class="media-card-body">
            <p class="media-card-date">{video.date}</p>
            <h3 class="media-card-title">{video.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<LogosBar class="fade-in" />

<section class="subscribe-band fade-in">
  <div class="container">
    <h3>Stay Informed</h3>
    <p>Subscribe to access our latest research and media appearances.</p>
    <form class="subscribe-form" action={`${site.mailchimpAction}?u=${site.mailchimpU}&id=${site.mailchimpId}`} method="POST" data-mailchimp>
      <input type="hidden" name="u" value={site.mailchimpU}>
      <input type="hidden" name="id" value={site.mailchimpId}>
      <input type="hidden" name="SIGNUP_SOURCE" value="website-newsletter">
      <label for="subscribe-email" class="visually-hidden">Email Address</label>
      <input type="email" id="subscribe-email" name="EMAIL" placeholder="Your email address" required>
      <div style="position:absolute;left:-5000px;" aria-hidden="true"><input type="text" name={`b_${site.mailchimpU}_${site.mailchimpId}`} tabindex="-1" value=""></div>
      <button type="submit">Subscribe</button>
    </form>
    <p class="subscribe-note">No spam. Unsubscribe anytime.</p>
  </div>
</section>

</BaseLayout>
