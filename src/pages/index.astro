---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { site } from '../data/site';
import { mediaVideos } from '../data/media-videos';
import LogosBar from '../components/LogosBar.astro';

const allResearch = await getCollection('research');
const latestResearch = allResearch
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const latestMedia = mediaVideos.slice(0, 3);
---

<BaseLayout isHome={true}>

