---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { site } from '../data/site';

const allCareers = await getCollection('careers', ({ data }) => !data.draft);
allCareers.sort((a, b) => {
  const orderA = a.data.order ?? Number.MAX_SAFE_INTEGER;
  const orderB = b.data.order ?? Number.MAX_SAFE_INTEGER;
  if (orderA !== orderB) return orderA - orderB;
  return b.data.postedDate.getTime() - a.data.postedDate.getTime();
});

const careerListings = await Promise.all(
  allCareers.map(async (entry) => ({
    id: entry.id,
    data: entry.data,
    Content: (await render(entry)).Content,
  }))
);
const firstCareerTitle = careerListings[0]?.data.title ?? '';
---

<BaseLayout title="Contact" description="Reach out to learn more about Monachil Capital Partners or explore career opportunities.">

<section class="page-hero">
  <div class="container">
    <p class="page-hero-breadcrumb"><a href="/">Home</a> / Contact</p>
    <h1>Get in <strong>Touch</strong></h1>
    <p class="page-hero-sub">Reach out to learn more about Monachil Capital Partners or explore career opportunities.</p>
    <div class="page-hero-rule"></div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-tabs">
      <button class="contact-tab contact-tab--active" data-tab="contact">Contact Us</button>
      <button class="contact-tab" data-tab="careers">Careers</button>
    </div>

    <div class="contact-pane contact-pane--active" id="pane-contact">
      <div class="contact-grid">
        <div class="contact-info">
          <h3>Monachil Capital Partners</h3>
          <p>For inquiries about our investment strategies, partnership opportunities, or general questions, please use the form or contact us directly.</p>
          <div class="contact-detail">
            <p class="contact-detail-label">Address</p>
            <p class="contact-detail-value">{site.address}<br />{site.city}</p>
          </div>
          <div class="contact-detail">
            <p class="contact-detail-label">Phone</p>
            <p class="contact-detail-value">{site.phone}</p>
          </div>
          <div class="contact-detail">
            <p class="contact-detail-label">Email</p>
            <p class="contact-detail-value"><a href={`mailto:${site.email}`} class="link-blue">{site.email}</a></p>
          </div>
          <div class="contact-detail">
            <p class="contact-detail-label">Public Funds</p>
            <p class="contact-detail-value"><a href={site.fundURL} target="_blank" rel="noopener" class="link-blue">monachilfunds.com &nearr;</a></p>
          </div>
        </div>

        <div>
          <form action={`https://formsubmit.co/ajax/${site.formInfoEmail}`} method="POST" data-formsubmit-ajax novalidate>
            <input type="hidden" name="_subject" value="Contact Form — Monachil Capital Partners">
            <input type="hidden" name="_template" value="table">
            <input type="hidden" name="_captcha" value="false">
            <input type="text" name="_honey" tabindex="-1" autocomplete="off" hidden aria-hidden="true">
            <div class="form-row">
              <div class="form-group">
                <label for="first-name">First Name <span class="form-required">*</span></label>
                <input type="text" id="first-name" name="first_name" required aria-required="true" autocomplete="given-name">
              </div>
              <div class="form-group">
                <label for="last-name">Last Name <span class="form-required">*</span></label>
                <input type="text" id="last-name" name="last_name" required aria-required="true" autocomplete="family-name">
              </div>
            </div>
            <div class="form-group">
              <label for="email">Email Address <span class="form-required">*</span></label>
              <input type="email" id="email" name="email" required aria-required="true" autocomplete="email">
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="company">Company</label>
                <input type="text" id="company" name="company" autocomplete="organization">
              </div>
              <div class="form-group">
                <label for="job-title">Job Title</label>
                <input type="text" id="job-title" name="job_title" autocomplete="organization-title">
              </div>
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel">
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <select id="subject" name="subject">
                <option value="">Select a topic...</option>
                <option value="general">General Inquiry</option>
                <option value="investment">Investment Inquiry</option>
                <option value="originator">Originator / Capital Solutions Inquiry</option>
                <option value="media">Media Inquiry</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Message <span class="form-required">*</span></label>
              <textarea id="message" name="message" rows="5" required aria-required="true"></textarea>
            </div>
            <div class="form-group form-checkbox-group">
              <label class="form-checkbox-label">
                <input type="checkbox" name="newsletter" value="yes">
                <span>Subscribe to our newsletter for monthly market commentary and research updates</span>
              </label>
            </div>
            <button type="submit" class="btn btn--primary btn-full">Send Message</button>
          </form>
        </div>
      </div>
    </div>

    <div class="contact-pane" id="pane-careers">
      <div class="careers-intro">
        <h2>Join the <strong>Team</strong></h2>
        <p>We are always seeking top talent to join our team of industry professionals. Select an open role to view details, then apply below.</p>
      </div>

      {careerListings.length === 0 ? (
        <div class="careers-empty">
          <p>We don't have any open positions at the moment, but we welcome speculative introductions. Please reach out via the Contact tab with a note on how you could contribute.</p>
        </div>
      ) : (
        <div class="careers-split">
          <aside class="careers-split-list" aria-label="Open positions">
            <p class="careers-split-list-title">Open Positions <span class="careers-split-list-count">({careerListings.length})</span></p>
            <ul class="position-list" role="tablist" aria-orientation="vertical">
              {careerListings.map((job, i) => (
                <li role="none">
                  <button
                    type="button"
                    role="tab"
                    class={`position-item${i === 0 ? ' position-item--active' : ''}`}
                    data-position={job.data.title}
                    data-panel={`position-panel-${job.id}`}
                    aria-selected={i === 0 ? 'true' : 'false'}
                    aria-controls={`position-panel-${job.id}`}
                    id={`position-tab-${job.id}`}
                    tabindex={i === 0 ? 0 : -1}
                  >
                    <span class="position-item-tag">{job.data.tag}</span>
                    <span class="position-item-title">{job.data.title}</span>
                    <span class="position-item-meta">{job.data.location} &middot; {job.data.employmentType}</span>
                  </button>
                </li>
              ))}
            </ul>
          </aside>

          <div class="careers-split-main">
            {careerListings.map((job, i) => (
              <article
                class={`position-panel${i === 0 ? ' position-panel--active' : ''}`}
                id={`position-panel-${job.id}`}
                role="tabpanel"
                aria-labelledby={`position-tab-${job.id}`}
                hidden={i !== 0}
                tabindex="0"
              >
                <header class="position-panel-header">
                  <span class="position-panel-tag">{job.data.tag}</span>
                  <h3 class="position-panel-title">{job.data.title}</h3>
                  <p class="position-panel-meta">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span>{job.data.location}</span>
                    <span class="position-panel-meta-sep" aria-hidden="true">&middot;</span>
                    <span>{job.data.employmentType}</span>
                  </p>
                </header>
                <div class="position-panel-body">
                  <job.Content />
                </div>
              </article>
            ))}

            <div class="careers-form-wrapper" id="careers-apply">
              <div class="careers-form-header">
                <p class="careers-form-eyebrow">Apply now</p>
                <p class="careers-form-applying">
                  Applying for
                  <strong id="app-applying-for-display">{firstCareerTitle}</strong>
                </p>
              </div>
              <form action={`https://formsubmit.co/${site.formHrEmail}`} method="POST" enctype="multipart/form-data" data-careers novalidate>
                <input type="hidden" name="_subject" value="Career Application — Monachil Capital Partners">
                <input type="hidden" name="_template" value="table">
                <input type="hidden" name="_captcha" value="false">
                <input type="hidden" name="_next" value="https://monachill.com/contact/?submitted=careers">
                <input type="text" name="_honey" tabindex="-1" autocomplete="off" hidden aria-hidden="true">
                <input type="hidden" name="position" id="app-position" value={firstCareerTitle}>
                <div class="form-row">
                  <div class="form-group">
                    <label for="app-name">Full Name <span class="form-required">*</span></label>
                    <input type="text" id="app-name" name="name" required aria-required="true" autocomplete="name">
                  </div>
                  <div class="form-group">
                    <label for="app-email">Email Address <span class="form-required">*</span></label>
                    <input type="email" id="app-email" name="email" required aria-required="true" autocomplete="email">
                  </div>
                </div>
                <div class="form-group">
                  <label for="app-linkedin">LinkedIn Profile URL</label>
                  <input type="url" id="app-linkedin" name="linkedin" placeholder="https://linkedin.com/in/yourprofile" autocomplete="url">
                </div>
                <div class="form-group">
                  <label for="app-resume">Resume <span class="form-required">*</span></label>
                  <input type="file" id="app-resume" name="resume" accept=".pdf,.doc,.docx" required aria-required="true" aria-describedby="app-resume-help" class="form-file-input" data-max-size="10485760">
                  <p id="app-resume-help" class="form-help-text">PDF, DOC, or DOCX. Maximum 10MB.</p>
                </div>
                <div class="form-group">
                  <label for="app-message">Cover Letter / Message</label>
                  <textarea id="app-message" name="message" rows="4" placeholder="Tell us about yourself and why you're interested in this role..."></textarea>
                </div>
                <div class="form-group">
                  <label for="app-referral">Referral Code <span class="form-optional">(optional)</span></label>
                  <input type="text" id="app-referral" name="referral_code" autocomplete="off" placeholder="If someone referred you, enter their code here">
                </div>
                <button type="submit" class="btn btn--primary btn-full">Submit Application</button>
              </form>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

</BaseLayout>
