---
import '../assets/css/global.css';
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/layout/BaseHead.astro';
import StructuredData from '../components/layout/StructuredData.astro';
import { site } from '../data/site';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  thumbnail?: string;
  section?: string;
  date?: Date;
  lastmod?: Date;
  permalink?: string;
  isHome?: boolean;
}

const props = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead {...props} />
  <StructuredData
    section={props.section}
    title={props.title}
    description={props.description}
    date={props.date}
    lastmod={props.lastmod}
    permalink={props.permalink}
  />
  <ClientRouter />
  <script is:inline>
    (function(){
      var s = localStorage.getItem('theme');
      var os = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      document.documentElement.dataset.theme = s || os;
    })();
  </script>
  <slot name="head" />
</head>
<body>
  <div class="scroll-progress" id="scrollProgress"></div>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <Nav />
  <main id="main-content">
    <slot />
  </main>
  <Footer />

  <div class="gate-modal" id="gateModal">
    <div class="gate-modal-inner">
      <button class="gate-modal-close" id="gateModalClose" aria-label="Close">&times;</button>
      <h3 class="gate-modal-title">Access This Report</h3>
      <p class="gate-modal-desc">Enter your email to download the PDF.</p>
      <form class="gate-modal-form" id="gateForm" action={`${site.mailchimpAction}?u=${site.mailchimpU}&id=${site.mailchimpId}`} method="POST" data-mailchimp>
        <input type="hidden" name="u" value={site.mailchimpU}>
        <input type="hidden" name="id" value={site.mailchimpId}>
        <input type="hidden" name="RESOURCE" id="gateResource" value="">
        <input type="hidden" name="SIGNUP_SOURCE" value="pdf-download">
        <div style="position:absolute;left:-5000px;" aria-hidden="true"><input type="text" name={`b_${site.mailchimpU}_${site.mailchimpId}`} tabindex="-1" value=""></div>
        <input type="email" name="EMAIL" id="gateEmail" placeholder="Your email address" required>
        <label class="gate-checkbox">
          <input type="checkbox" name="NEWSLETTER" id="gateNewsletter" value="yes">
          <span>Also subscribe to our research and media updates</span>
        </label>
        <button type="submit" class="btn btn--primary">Download PDF</button>
      </form>
      <p class="gate-modal-note">Your email is used solely to deliver this report unless you opt in above.</p>
    </div>
  </div>

  <div class="video-modal" id="videoModal">
    <div class="video-modal-inner">
      <button class="video-modal-close" id="videoModalClose" aria-label="Close video">&times;</button>
      <div class="video-modal-player" id="videoModalPlayer"></div>
    </div>
  </div>

  <script is:inline>
  // ── Global listeners (bound ONCE, never duplicated) ──
  var _globalsBound = false;

  function showMessage(container, type, text, duration) {
    var existing = container.querySelector('.form-message');
    if (existing) existing.remove();
    var msg = document.createElement('div');
    msg.className = 'form-message form-message--' + type;
    msg.textContent = text;
    msg.setAttribute('role', 'status');
    container.appendChild(msg);
    setTimeout(function() { msg.remove(); }, duration || 6000);
  }

  function openVideo(src) {
    var modal = document.getElementById('videoModal');
    var player = document.getElementById('videoModalPlayer');
    if (!modal || !player) return;
    player.innerHTML = '<iframe src="' + src + '" title="Video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>';
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeVideo() {
    var modal = document.getElementById('videoModal');
    var player = document.getElementById('videoModalPlayer');
    if (!modal) return;
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    if (player) player.innerHTML = '';
  }

  var _gatePdfUrl = '';
  function openGate(pdfUrl, resource) {
    _gatePdfUrl = pdfUrl;
    var modal = document.getElementById('gateModal');
    var resourceInput = document.getElementById('gateResource');
    if (resourceInput) resourceInput.value = resource || pdfUrl.split('/').pop().replace('.pdf', '');
    if (modal) { modal.classList.add('is-open'); document.body.style.overflow = 'hidden'; }
  }
  function closeGate() {
    var modal = document.getElementById('gateModal');
    if (modal) { modal.classList.remove('is-open'); document.body.style.overflow = ''; }
    _gatePdfUrl = '';
  }

  function closeMenu() {
    var overlay = document.getElementById('menuOverlay');
    if (overlay) { overlay.classList.remove('is-open'); document.body.style.overflow = ''; }
  }

  function toggleTheme() {
    var current = document.documentElement.dataset.theme;
    var next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
    updateToggleButton(next);
  }

  function updateToggleButton(theme) {
    var btn = document.getElementById('themeToggle');
    if (!btn) return;
    btn.setAttribute('aria-label', theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
    btn.setAttribute('aria-checked', theme === 'light' ? 'true' : 'false');
    btn.innerHTML = theme === 'dark'
      ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>'
      : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
  }

  function bindGlobalListeners() {
    if (_globalsBound) return;
    _globalsBound = true;

    // Single scroll handler for nav, progress bar, and parallax
    window.addEventListener('scroll', function() {
      var nav = document.getElementById('nav');
      var scrollBar = document.getElementById('scrollProgress');
      if (nav) nav.classList.toggle('nav--scrolled', window.scrollY > 10);
      if (scrollBar) {
        var dh = document.documentElement.scrollHeight - window.innerHeight;
        scrollBar.style.width = dh > 0 ? (window.scrollY / dh * 100) + '%' : '0%';
      }
    }, { passive: true });

    // Parallax (separate RAF-throttled handler)
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      var pTicking = false;
      window.addEventListener('scroll', function() {
        if (pTicking) return;
        pTicking = true;
        requestAnimationFrame(function() {
          document.querySelectorAll('.section-title').forEach(function(h) {
            var r = h.getBoundingClientRect();
            if (r.top < window.innerHeight && r.bottom > 0) {
              h.style.transform = 'translateY(' + (r.top - window.innerHeight * 0.5) * 0.04 + 'px)';
            }
          });
          pTicking = false;
        });
      }, { passive: true });
    }

    // Global keyboard handler
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeMenu();
        closeVideo();
        closeGate();
      }
    });

    // Global click delegation for interactive elements
    document.addEventListener('click', function(e) {
      var target = e.target;

      // Theme toggle
      if (target.closest('#themeToggle')) { toggleTheme(); return; }

      // Menu open/close
      if (target.closest('#navToggle')) {
        var overlay = document.getElementById('menuOverlay');
        if (overlay) { overlay.classList.add('is-open'); document.body.style.overflow = 'hidden'; }
        return;
      }
      if (target.closest('#menuClose')) { closeMenu(); return; }
      if (target.id === 'menuOverlay') { closeMenu(); return; }

      // Video modal close
      if (target.closest('#videoModalClose')) { closeVideo(); return; }
      if (target.id === 'videoModal') { closeVideo(); return; }

      // Gate modal close
      if (target.closest('#gateModalClose')) { closeGate(); return; }
      if (target.id === 'gateModal') { closeGate(); return; }

      // Gated PDF download button
      var gateBtn = target.closest('.btn-gated');
      if (gateBtn) {
        var pdfUrl = gateBtn.dataset.gatePdf;
        var resource = gateBtn.dataset.gateResource;
        if (pdfUrl) {
          // Check if user already provided email
          if (localStorage.getItem('gate_email')) {
            window.open(pdfUrl, '_blank');
          } else {
            openGate(pdfUrl, resource);
          }
        }
        return;
      }

      // Embeddable media cards
      var embedCard = target.closest('.media-card--embed');
      if (embedCard) {
        var ytId = embedCard.dataset.youtube;
        var embedUrl = embedCard.dataset.embed;
        if (ytId) openVideo('https://www.youtube.com/embed/' + ytId + '?autoplay=1&rel=0&modestbranding=1');
        else if (embedUrl) openVideo(embedUrl);
        return;
      }

      // Contact tabs
      var contactTab = target.closest('.contact-tab');
      if (contactTab) {
        document.querySelectorAll('.contact-tab').forEach(function(t) { t.classList.remove('contact-tab--active'); });
        document.querySelectorAll('.contact-pane').forEach(function(p) { p.classList.remove('contact-pane--active'); });
        contactTab.classList.add('contact-tab--active');
        var pane = document.getElementById('pane-' + contactTab.dataset.tab);
        if (pane) pane.classList.add('contact-pane--active');
        return;
      }

      // Page tabs
      var pageTab = target.closest('.page-tab');
      if (pageTab) {
        document.querySelectorAll('.page-tab').forEach(function(t) { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
        document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('is-active'); });
        pageTab.classList.add('is-active');
        pageTab.setAttribute('aria-selected', 'true');
        var panel = document.getElementById(pageTab.getAttribute('aria-controls'));
        if (panel) panel.classList.add('is-active');
        return;
      }

      // Position cards
      var posCard = target.closest('.position-card[data-position]');
      if (posCard) {
        document.querySelectorAll('.position-card').forEach(function(c) { c.classList.remove('position-card--active'); });
        posCard.classList.add('position-card--active');
        var radios = document.querySelectorAll('input[name="position"]');
        radios.forEach(function(r) { if (r.value === posCard.dataset.position) r.checked = true; });
        return;
      }

      // Year filter buttons
      var filterBtn = target.closest('.year-filter-btn');
      if (filterBtn) {
        var year = filterBtn.dataset.year;
        document.querySelectorAll('.year-filter-btn').forEach(function(b) { b.classList.remove('is-active'); });
        filterBtn.classList.add('is-active');
        var count = 0;
        document.querySelectorAll('[data-year]:not(.year-filter-btn)').forEach(function(item) {
          var show = year === 'all' || item.dataset.year === year;
          item.style.display = show ? '' : 'none';
          if (show) count++;
        });
        var counter = document.getElementById('research-visible-count');
        if (counter) counter.textContent = count;
        return;
      }
    });

    // Form submission (delegated)
    document.addEventListener('submit', function(e) {
      var form = e.target;
      var btn = form.querySelector('button[type="submit"]');
      if (!btn) return;
      var originalText = btn.textContent;

      // Mailchimp forms — submit via hidden iframe to avoid redirect
      if (form.hasAttribute('data-mailchimp')) {
        e.preventDefault();
        var isGateForm = form.id === 'gateForm';
        var emailValue = form.querySelector('input[name="EMAIL"]')?.value;
        btn.textContent = isGateForm ? 'Processing...' : 'Subscribing...';
        btn.disabled = true;

        var iframeName = 'mc-iframe-' + Date.now();
        var iframe = document.createElement('iframe');
        iframe.name = iframeName;
        iframe.style.display = 'none';
        document.body.appendChild(iframe);

        form.target = iframeName;
        form.submit();

        setTimeout(function() {
          form.reset();
          form.target = '';
          btn.textContent = originalText;
          btn.disabled = false;
          iframe.remove();

          if (isGateForm && _gatePdfUrl) {
            // Save email to localStorage so they won't be asked again
            localStorage.setItem('gate_email', emailValue);
            // Trigger download
            window.open(_gatePdfUrl, '_blank');
            closeGate();
          } else {
            showMessage(form.parentElement, 'success', 'Thank you! Please check your email to confirm your subscription.');
          }
        }, 2000);
        return;
      }

      // Formspree forms (contact, careers)
      if (!form.action || form.action.indexOf('formspree.io') === -1) return;
      e.preventDefault();
      btn.textContent = 'Sending...';
      btn.disabled = true;

      fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      }).then(function(res) {
        if (res.ok) { form.reset(); showMessage(form.parentElement, 'success', 'Thank you! Your message has been sent.'); }
        else showMessage(form.parentElement, 'error', 'Something went wrong. Please try again.');
      }).catch(function() {
        showMessage(form.parentElement, 'error', 'Network error. Please check your connection and try again.');
      }).finally(function() { btn.textContent = originalText; btn.disabled = false; });
    });

    // OS theme change listener
    window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function(e) {
      if (!localStorage.getItem('theme')) {
        document.documentElement.dataset.theme = e.matches ? 'light' : 'dark';
        updateToggleButton(e.matches ? 'light' : 'dark');
      }
    });
  }

  // ── Per-page init (safe to call multiple times) ──
  function initPage() {
    // Fade-in observers (safe: unobserve on trigger)
    document.documentElement.classList.add('js-fade-ready');
    var faders = document.querySelectorAll('.fade-in:not(.is-visible)');
    if (faders.length && 'IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { entry.target.classList.add('is-visible'); obs.unobserve(entry.target); }
        });
      }, { threshold: 0.1 });
      faders.forEach(function(el) { obs.observe(el); });
    } else {
      faders.forEach(function(el) { el.classList.add('is-visible'); });
    }

    // Stat counter observers (safe: unobserve on trigger)
    var stats = document.querySelectorAll('.stat-number:not(.stat-counted)');
    if (stats.length && 'IntersectionObserver' in window) {
      var sObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { entry.target.classList.add('stat-counted'); sObs.unobserve(entry.target); }
        });
      }, { threshold: 0.5 });
      stats.forEach(function(el) { sObs.observe(el); });
    }

    // Hash-based tab activation
    var hash = window.location.hash.slice(1);
    if (hash === 'careers') {
      var ct = document.querySelector('.contact-tab[data-tab="careers"]');
      if (ct) ct.click();
    }
    if (hash === 'team') { var t = document.getElementById('tab-team'); if (t) t.click(); }
    if (hash === 'press') { var p = document.getElementById('tab-press'); if (p) p.click(); }

    // Gated PDF: show direct download for returning visitors
    if (localStorage.getItem('gate_email')) {
      document.querySelectorAll('.btn-gated').forEach(function(btn) { btn.style.display = 'none'; });
      document.querySelectorAll('.btn-gated-direct').forEach(function(btn) { btn.style.display = ''; });
    }

    // Update theme toggle icon
    updateToggleButton(document.documentElement.dataset.theme);
  }

  // Re-apply theme after Astro client-side navigation
  document.addEventListener('astro:after-swap', function() {
    var s = localStorage.getItem('theme');
    var os = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    document.documentElement.dataset.theme = s || os;
  });

  // Bind globals once, then run per-page init on each navigation
  document.addEventListener('astro:page-load', function() {
    bindGlobalListeners();
    initPage();
  });
  </script>
</body>
</html>
